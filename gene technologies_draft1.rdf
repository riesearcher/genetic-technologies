    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inactivate_aminoglycoside_antibiotics -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inactivate_aminoglycoside_antibiotics">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#antibiotic_resistance"/>
        <rdfs:comment>a design to create aminoglycosideantibiotics such as spectinomycin and streptomycin
by using marker assisten selection technology
the aad gene from Eschericia coli expressed enzyme that allows selection for resistance to aminoglycoside antibiotics such as spectinomycin and streptomycin</rdfs:comment>
    </owl:NamedIndividual>
    


