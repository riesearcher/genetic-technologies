    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#toxic_to_insect -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#toxic_to_insect">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
