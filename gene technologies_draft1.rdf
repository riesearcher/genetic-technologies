    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#amino_acid_truncation_in_UGP3_enzyme -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#amino_acid_truncation_in_UGP3_enzyme">
