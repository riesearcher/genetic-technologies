        <hasSpecies rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#Escherichia_coli"/>
        <hasSpecies rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#Streptomyces_hygroscopicus"/>
        <hasSpecies rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#canola"/>
        <authorisation_country>Australia</authorisation_country>
