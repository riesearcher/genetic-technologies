    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mutate_sbAHAS_protein -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mutate_sbAHAS_protein">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#chemical_mutagenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#herbicide_tolerance"/>
        <rdfs:comment>a design to develop imidazolinone-tolerant grain sorghum using chemical induction of   ethyl methanesulfonate (EMS). The mutation responsible for imidazolinone tolerance in ADV-IMI-R grain sorghum is a single nucleotide change of guanine to adenine at position +277, which results in a codon change from GCG to ACG which results in a single amino acid substitution of alanine to threonine at position 93 (A93T) in the sbAHAS protein.</rdfs:comment>
        <rdfs:comment>sbAHAS: acetohydroxyacid synthase</rdfs:comment>
    </owl:NamedIndividual>
    


