    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#modify_hppd_enzyme -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#modify_hppd_enzyme">
