    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_barnase_inhibitor -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_barnase_inhibitor">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#fertility_restoration"/>
        <rdfs:comment>a design to create fertility restoration trait
using transgenic technology
fertility restoration trait resulted from barstar gene introduction from bacterium 	Bacillus amyloliquefaciens, the over expression of the gene produce barnase ribonuclease inhibitor on tapetum cells ot the anther</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_blue_stain_on_tissue -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_blue_stain_on_tissue">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#visual_selection"/>
        <has_new_protein>beta-D-glucuronidase (GUS)</has_new_protein>
        <rdfs:comment>a design to allow visual selectionby using transgenic technology
The gene introduced is uidA derived from Eschericia coli, over expressed to create 	beta-D-glucuronidase (GUS) enzyme</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_coat_protein_of_potato_virus_Y -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_coat_protein_of_potato_virus_Y">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#virus_resistance"/>
        <rdfs:comment>a design to create viral disease resistance for potato by using transgenic technology
the overexpression of transgene PVY coat protein derived from potato virus Y produce PVY coat protein that confers resistance to potato virus Y (PVY)</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_coat_protein_of_the_PRSV -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_coat_protein_of_the_PRSV">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
