    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#application -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#application">
        <rdfs:comment>application = f(product, challenge, Σ(protocol), local context)</rdfs:comment>
        <rdfs:comment>standardised product usage based on local context to address challenge</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#assessment -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#assessment">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#local_context"/>
        <rdfs:comment>the action of assessing a product before it can be released</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#authorisation -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#authorisation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#local_context"/>
        <rdfs:comment>formal approval of the product</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biofortified -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biofortified">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#trait"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biotechnology -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biotechnology">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#technology"/>
        <rdfs:comment>https://doi.org/10.1016/j.techsoc.2012.07.004; https://doi.org/10.1146/annurev.resource.050708.144203</rdfs:comment>
        <rdfs:comment>the application of biological systems and organisms to develop products and technologies</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biotic_challenge -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biotic_challenge">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#challenge"/>
        <rdfs:comment>challenge caused by living organisms</rdfs:comment>
        <rdfs:comment>https://doi.org/10.3389/fpls.2020.601009; https://doi.org/10.3389/fpls.2017.00537</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biotic"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#challenge -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#challenge">
        <rdfs:comment>what that drives product design​, such as a problem</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#consequences -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#consequences">
        <rdfs:comment>consequences ∝ application</rdfs:comment>
        <rdfs:comment>consequences ∝ challenge, Σ(species), Σ(technology), Σ(protocol), Σ(trait), current knowledge, local context</rdfs:comment>
        <rdfs:comment>the impact of applying a product</rdfs:comment>
    </owl:Class>
    


