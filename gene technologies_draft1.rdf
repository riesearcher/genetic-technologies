    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#Foray_48B -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#Foray_48B">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#pesticide"/>
        <hasDesign rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#stops_larvacidal_activity"/>
        <hasSpecies rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#Bacillus_thuringiensis"/>
        <developed_by>Valent BioSciences LLC.</developed_by>
        <rdfs:comment>A biological insecticide for the control of lepidopterous larvae. It contains the spores and endotoxin crystals of Bacillus thuringiensis kurstaki. Susceptible larvae that ingest Foray 48B cease feeding within a few hours and die within 2-5 days.</rdfs:comment>
        <rdfs:comment>https://www.valentbiosciences.com/foresthealth/wp-content/uploads/sites/5/2021/04/Valent_Foray-48B-44-label.pdf
https://www.valentbiosciences.com/foresthealth/wp-content/uploads/sites/5/2017/03/SDS-VBC-0075R5-Foray-48B-01-20-2020-.pdf</rdfs:comment>
    </owl:NamedIndividual>
    


