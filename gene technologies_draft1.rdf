    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inhibit_ALS_herbicides -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inhibit_ALS_herbicides">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#cisgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#herbicide_tolerance"/>
        <has_new_protein>acetolactate synthase (ALS)</has_new_protein>
        <rdfs:comment>a design to create acetolactate synthase (ALS) herbicide tolerance using cisgenic technology
The tolerance trait expressed from the introduction of gm-hra gene derived from Glycine max producing modified acetolactate synthase (ALS) enzyme</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inhibit_viral_replication_protein -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inhibit_viral_replication_protein">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#disease_resistance"/>
        <rdfs:comment>a design to create viral disease resistance by using transgenic technology.
gene intriduced: ac1 (sense and antisense) derived from Bean Golden Mosaic Virus (BGMV), its overexpression inhibits the synthesis of the viral replication protein of the Bean Golden Mosaic Virus (BGMV), thereby conferring resistance to the BGMV</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inhibits_polygalacturonase_enzyme -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#inhibits_polygalacturonase_enzyme">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#knockout"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#cisgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#delayed_fruit_softening"/>
        <rdfs:comment>a design to create delayed fruit softening trait
using cisgenic technology
gene introduced is pg gene from the same species (Solanum lycopersicum)
the gene knock out the production of polygalacturonase enzyme that is responsible for the breakdown of pectin molecules in the cell wall, and thus causes delayed softening of the fruit</rdfs:comment>
    </owl:NamedIndividual>
    


