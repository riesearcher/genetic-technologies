    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increased_triacylglycerides_level -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increased_triacylglycerides_level">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#higher_oleic_acid_content"/>
        <rdfs:comment>a design to create:
modified oil/fatty acid trait so that the product has a better quality
using transgenic technology
gene introduced te from bay leaf (Umbellularia californica)
technology protocol te gene overexpression creates 12:0 ACP thioesterase  enzyme to increase oleic acid content.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increased_yield_quantity -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increased_yield_quantity">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#production_consequences"/>
