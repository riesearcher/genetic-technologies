    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#DiPel_DF -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#DiPel_DF">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#pesticide"/>
        <hasDesign rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#stops_caterpillar_feeding_activity"/>
        <hasSpecies rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#Bacillus_thuringiensis"/>
        <developed_by>Sumitomo Chemical</developed_by>
        <resistance_to_insect>Lepidoptera</resistance_to_insect>
        <rdfs:comment>Biological insecticide with dry flowable formulation that contains live spores and endotoxin of a naturally occurring bacterium, Bacillus thuringiensis subsp. kurstaki. to stop Lepidopteran caterpillars eating the foliage and kill the caterpillars within 3-4 days</rdfs:comment>
        <rdfs:comment>applied during early window, around September to Late January</rdfs:comment>
        <rdfs:comment>compatible to use in: Vegetables, Fruit, Vines, Oilseeds, Cereal Grains, Herbs, Tobacco, Ornamentals, Forestry, Amenity Trees and Turf.</rdfs:comment>
        <rdfs:comment>https://www.sumitomo-chem.com.au/sites/default/files/sds-label/dipel_df_web_label_0222.pdf
https://nwlivestock.com.au/product/dipel-df-insecticide-500g/?srsltid=AfmBOooCPRB7cNS0g12I5mwtl3cxQyAHjWXQYDhjZ-kFWHbf2eynhDAN</rdfs:comment>
    </owl:NamedIndividual>
    


