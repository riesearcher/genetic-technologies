    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#reduce_herbicide_bioactivity">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#herbicide_tolerance"/>
        <has_new_protein>modified p-hydroxyphenylpyruvate dioxygenase (hppd)</has_new_protein>
        <rdfs:comment>a design to create isoxaflutole herbicide tolerance by using transgenic technology. The introduction of hppdPF W336 transgene derived from Pseudomonas fluorescens strain A32 produces modified p-hydroxyphenylpyruvate dioxygenase (hppd) enzyme that could confers tolerance to HPPD-inhibiting herbicides (such as isoxaflutole) by reducing the specificity for the herbicide&apos;s bioactive constituent</rdfs:comment>
    </owl:NamedIndividual>
    


