    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increase_encoded_phytase_thermotolerance -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increase_encoded_phytase_thermotolerance">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#phytase_production"/>
        <rdfs:comment>a design to produce phytase enzyme
using transgenic technology
gene introduced phy02 from Eschericia coli 
technology procedure: phy02 gene overexpression optimised phytase enzyme that can  increase the thermotolerance of the encoded PHY02 phytase and its susceptibility to digestion in the gastric environment of monogastric animals</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increase_the_breakdown_of_phytates -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increase_the_breakdown_of_phytates">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#phytase_production"/>
        <rdfs:comment>a design to produce 3-phytase enzyme
using transgenic technology
gene introduced: phyA from Aspergillus niger var. van Tieghem
technology procedure: phyA gene overexpression produce phytase which bind phosphorus and makes the latter available to monogastric animals</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#increased_farmer_income -->

