        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#disease_resistance"/>
        <rdfs:comment>a design to create viral disease resistance trait from the expression of PRSV CP gene derived from the papaya ringspot virus strain PRSV HA 5-1 as a result from a trangenic technology</rdfs:comment>
        <rdfs:comment>a design to create viral disease resistance trait from the expression of PRSV CP gene derived from the papaya ringspot virus strain PRSV HA 5-1. The modification was a result of using particle mediated transformation which introduced a DNA construct into papaya plant cells.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_enzyme_to_metabolise_mannose -->

