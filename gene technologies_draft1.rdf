    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#abiotic_challenge -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#abiotic_challenge">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#challenge"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#biotic_challenge"/>
        <rdfs:comment>challenge arises from non-living environmental factors</rdfs:comment>
        <rdfs:comment>https://doi.org/10.3389/fpls.2020.601009; https://doi.org/10.1007/s00425-003-1105-5; https://doi.org/10.1016/j.cell.2016.08.029</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#abiotic"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#adoption_experience -->

    <owl:Class rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#adoption_experience">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#survey_things"/>
        <rdfs:comment>whether or not the farmer has ever adopted innovations related to pest and disease control in their citrus cultivation</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#animal -->

