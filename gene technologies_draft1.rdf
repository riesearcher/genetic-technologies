    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#eliminate_herbicidal_activity_of_bromoxynil -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#eliminate_herbicidal_activity_of_bromoxynil">
