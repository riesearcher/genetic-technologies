    <rdf:Description rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression">
        <rdfs:comment>!!</rdfs:comment>
        <rdfs:comment>10.1007/s00425-020-03372-8; https://food.ec.europa.eu/; 10.3389/fpls.2021.657133</rdfs:comment>
        <rdfs:comment>The increased expression of a specific gene.</rdfs:comment>
        <rdfs:comment>the use of biotechnology to modify organism&apos;s genes to create desirable trait(s)</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#knockdown">
        <rdfs:comment>A technique that temporarily reduces the expression of a specific gene at the RNA level, without altering the DNA sequence.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#knockout">
        <rdfs:comment>!!</rdfs:comment>
        <rdfs:comment>A technique that permanently inactivates or removes one or more specific genes from an organism&apos;s genome.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mutagenesis">
        <rdfs:comment>Any change in the sequence of an organism’s genome.</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#weed">
        <rdfs:comment>wild unwanted plant that grows among the cultivated crops</rdfs:comment>
    </rdf:Description>
    


