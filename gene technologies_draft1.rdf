    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_ALS-inhibiting_enzyme -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_ALS-inhibiting_enzyme">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#natural_mutagenesis"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#selective_breeding"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#herbicide_tolerance"/>
        <rdfs:comment>[Sorghum Inzen]
a design to create herbicide tolerance trait through conventional plant breeding and selection techniques to incorporate a naturally occurring mutation within the ALS-encoding gene of a wild sorghum variety into the grain sorghum genome.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_APH4_enzyme -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#produce_APH4_enzyme">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#marker_assisted_selection"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#antibiotic_resistance"/>
        <rdfs:comment>a design to create resistance to antibiotic hygromycin
created from gene aph4(hpt) marker selection derived from Eschericia coli
the production of APH4 enzyme confers resistance to the antibiotic hygromycin.</rdfs:comment>
    </owl:NamedIndividual>
    


