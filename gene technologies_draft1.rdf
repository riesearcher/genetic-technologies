    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#decrease_binding_afinity_for_glyphosate -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#decrease_binding_afinity_for_glyphosate">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#herbicide_tolerance"/>
        <has_new_protein>5-enolpyruvyl shikimate-3-phosphate synthase</has_new_protein>
        <has_new_protein>herbicide tolerant form of 5-enolpyruvulshikimate-3-phosphate synthase (EPSPS)</has_new_protein>
        <rdfs:comment>[In Soybean MST-FGØ72-2]

a design to create isoflaxutole herbicide tolerance by using transgenic technology. the gene introduced is 2mepsps derived from Zea mays, the transgene overexpression produces 5-enolpyruvyl shikimate-3-phosphate synthase enzyme that could increase tolerance to glyphosate herbicide</rdfs:comment>
        <rdfs:comment>a design to create:
herbicide tolerant trait
using transgenic technology
gene intorduced: cp4 epsps from Agrobacterium tumefaciens strain CP4
technology protocol: cp4 epsps  gene overexpresion creates 5-enolpyruvulshikimate-3-phosphate synthase (EPSPS) enzyme</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#degrade_glyphosate -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#degrade_glyphosate">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#transgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#herbicide_tolerance"/>
        <has_new_protein>glyphosate oxidase</has_new_protein>
        <rdfs:comment>a design to create:
glyphosate herbicide tolerance trait
using transgenic technology
gene introduced: goxv247 from Ochrobactrum anthropi strain LBAA
technology procedure: goxv247 gene overexpression create glyphosate oxidase</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#degrades_mesotrione_herbicide -->

