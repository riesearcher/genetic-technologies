    <!-- http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#detect_infecting_fungus -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#detect_infecting_fungus">
        <rdf:type rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#mechanism"/>
        <hasProcedure rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#gene_overexpression"/>
        <hasTechnology rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#cisgenesis"/>
        <hasTrait rdf:resource="http://www.semanticweb.org/90958855/ontologies/2024/8/riesma_thesis#disease_resistance"/>
        <rdfs:comment>a design to create resistance to e fungal disease Fusarium wilt 
tropical race 4 (TR4)/Panama disease
using cisgenics technology 
gene introduced:  MamRGA2 gene from wild banana, Musa acuminata ssp. malaccensis. The MamRGA2 protein allows the banana plant to detect the presence of  the infecting fungus, which triggers the plant’s defence response preventing further infection by the fungus.</rdfs:comment>
    </owl:NamedIndividual>
    


